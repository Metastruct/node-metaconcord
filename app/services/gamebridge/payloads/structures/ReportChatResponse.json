{
	"$ref": "#/definitions/ReportChatResponse",
	"$schema": "http://json-schema.org/draft-07/schema#",
	"definitions": {
		"ReportChatResponse": {
			"additionalProperties": false,
			"properties": {
				"data": {
					"$ref": "#/definitions/ReportChatResponsePayload"
				},
				"name": {
					"const": "ReportChatPayload",
					"type": "string"
				}
			},
			"required": ["data", "name"],
			"type": "object"
		},
		"ReportChatResponsePayload": {
			"anyOf": [
				{
					"additionalProperties": false,
					"properties": {
						"content": {
							"type": "string"
						},
						"reporterSteamId64": {
							"type": "string"
						},
						"type": {
							"const": "message",
							"type": "string"
						},
						"username": {
							"type": "string"
						}
					},
					"required": ["type", "username", "content", "reporterSteamId64"],
					"type": "object"
				},
				{
					"additionalProperties": false,
					"properties": {
						"messages": {
							"items": {
								"additionalProperties": false,
								"properties": {
									"content": {
										"type": "string"
									},
									"username": {
										"type": "string"
									}
								},
								"required": ["username", "content"],
								"type": "object"
							},
							"type": "array"
						},
						"reporterSteamId64": {
							"type": "string"
						},
						"type": {
							"const": "queued",
							"type": "string"
						}
					},
					"required": ["type", "messages", "reporterSteamId64"],
					"type": "object"
				},
				{
					"additionalProperties": false,
					"properties": {
						"isResolved": {
							"const": true,
							"type": "boolean"
						},
						"reporterSteamId64": {
							"type": "string"
						},
						"resolvedBy": {
							"type": "string"
						},
						"type": {
							"const": "resolve",
							"type": "string"
						}
					},
					"required": ["type", "isResolved", "reporterSteamId64"],
					"type": "object"
				},
				{
					"additionalProperties": false,
					"properties": {
						"content": {
							"type": "string"
						},
						"reporterSteamId64": {
							"type": "string"
						},
						"type": {
							"const": "info",
							"type": "string"
						}
					},
					"required": ["type", "content", "reporterSteamId64"],
					"type": "object"
				}
			]
		}
	}
}
